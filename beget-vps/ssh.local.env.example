# Шаблон SSH-доступа к VPS Beget.
# 1) copy beget-vps\ssh.local.env.example beget-vps\ssh.local.env
# 2) Заполните данными из панели Beget → VPS.
# 3) ssh.local.env в Git не попадает (.gitignore).

VPS_HOST=123.45.67.89
VPS_PORT=22
VPS_USER=root
VPS_PASSWORD=

# Каталог приложения на сервере
VPS_APP_DIR=/opt/rental-bot
